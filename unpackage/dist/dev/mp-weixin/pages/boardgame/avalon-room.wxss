  min-height: 500rpx;
  position: relative;
  transform-style: preserve-3d;
  transition: transform 0.6s;
  cursor: pointer;
  --card-color: #666666;
}
.role-card.flipped.data-v-caed1a3f {
  transform: rotateY(180deg);
}
.card-front.data-v-caed1a3f, .card-back.data-v-caed1a3f {
  position: absolute;
  width: 100%;
  min-height: 500rpx;
  -webkit-backface-visibility: hidden;
          backface-visibility: hidden;
  border-radius: 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.3);
}
.card-front.data-v-caed1a3f {
  background: linear-gradient(135deg, #ffd700 0%, #ffed4e 100%);
  color: #1a1a2e;
  border: 2rpx solid #ffed4e;
}
.card-number.data-v-caed1a3f {
  font-size: 72rpx;
  font-weight: bold;
  margin-bottom: 20rpx;
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.1);
}
.card-hint.data-v-caed1a3f {
  font-size: 24rpx;
  opacity: 0.8;
}
.card-back.data-v-caed1a3f {
  background: var(--card-color);
  transform: rotateY(180deg);
  color: #ffffff;
  border: 2rpx solid var(--card-color);
  padding: 30rpx;
  text-align: center;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
}
.camp-info.data-v-caed1a3f {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 8rpx;
}
.camp-icon.data-v-caed1a3f {
  font-size: 24rpx;
}
.camp-name.data-v-caed1a3f {
  font-size: 24rpx;
  font-weight: 600;
}
.card-back .role-icon.data-v-caed1a3f {
  font-size: 100rpx;
  margin: 10rpx 0;
}
.card-back .role-name.data-v-caed1a3f {
  font-size: 32rpx;
  font-weight: bold;
  margin: 10rpx 0;
}
.card-divider.data-v-caed1a3f {
  width: 80%;
  height: 1rpx;
  background-color: rgba(255, 255, 255, 0.3);
  margin: 10rpx 0;
}
.skills-section.data-v-caed1a3f, .tips-section.data-v-caed1a3f, .seen-section.data-v-caed1a3f {
  width: 100%;
  text-align: left;
}
.section-title.data-v-caed1a3f {
  font-size: 20rpx;
  font-weight: 600;
  margin-bottom: 12rpx;
  display: block;
}
.skill-text.data-v-caed1a3f, .tips-text.data-v-caed1a3f, .seen-text.data-v-caed1a3f {
  font-size: 16rpx;
  line-height: 1.4;
  display: block;
  margin-bottom: 8rpx;
}
.confirm-btn.data-v-caed1a3f {
  width: 200rpx;
  margin-top: 20rpx;
}

/* 滚动条样式 */
.data-v-caed1a3f::-webkit-scrollbar {
  width: 8rpx;
  height: 8rpx;
}
.data-v-caed1a3f::-webkit-scrollbar-track {
  background: rgba(255, 255, 255, 0.1);
  border-radius: 4rpx;
}
.data-v-caed1a3f::-webkit-scrollbar-thumb {
  background: rgba(255, 215, 0, 0.5);
  border-radius: 4rpx;
}
.data-v-caed1a3f::-webkit-scrollbar-thumb:hover {
  background: rgba(255, 215, 0, 0.7);
}