<view class="timer-tool data-v-44d6a300" style="{{v}}"><view class="tool-header data-v-44d6a300"><text class="tool-title data-v-44d6a300">⏱️ 计时器</text><text class="tool-hint data-v-44d6a300">正计时 / 倒计时</text></view><view class="mode-tabs data-v-44d6a300"><view class="{{['mode-tab', 'data-v-44d6a300', a && 'active']}}" bindtap="{{b}}"><text class="data-v-44d6a300">正计时</text></view><view class="{{['mode-tab', 'data-v-44d6a300', c && 'active']}}" bindtap="{{d}}"><text class="data-v-44d6a300">倒计时</text></view></view><view class="time-display data-v-44d6a300"><text class="{{['time-value', 'data-v-44d6a300', f && 'warning']}}">{{e}}</text></view><view wx:if="{{g}}" class="countdown-setting data-v-44d6a300"><view class="time-picker data-v-44d6a300"><view class="picker-item data-v-44d6a300"><view class="picker-btn data-v-44d6a300" bindtap="{{h}}">+</view><text class="picker-value data-v-44d6a300">{{i}}</text><view class="picker-btn data-v-44d6a300" bindtap="{{j}}">-</view><text class="picker-label data-v-44d6a300">分</text></view><text class="picker-separator data-v-44d6a300">:</text><view class="picker-item data-v-44d6a300"><view class="picker-btn data-v-44d6a300" bindtap="{{k}}">+</view><text class="picker-value data-v-44d6a300">{{l}}</text><view class="picker-btn data-v-44d6a300" bindtap="{{m}}">-</view><text class="picker-label data-v-44d6a300">秒</text></view></view></view><view wx:if="{{n}}" class="progress-ring data-v-44d6a300"><view class="ring-inner data-v-44d6a300"><text class="ring-percent data-v-44d6a300">{{o}}%</text></view></view><view class="control-buttons data-v-44d6a300"><button wx:if="{{p}}" class="control-btn primary data-v-44d6a300" bindtap="{{r}}">{{q}}</button><button wx:else class="control-btn primary finished data-v-44d6a300" bindtap="{{s}}"> 重新开始 </button><button class="control-btn secondary data-v-44d6a300" bindtap="{{t}}"> 重置 </button></view></view>